      "folderID": null,
      "code": "export default async function main(args) {\n  const { inputVars } = args;\n  const responseText = \"Hello World\";\n\n  return {\n    trace: [\n      {\n        type: \"text\",\n        payload: {\n          message: `${responseText}`,\n        },\n      },\n    ],\n  };\n}",
