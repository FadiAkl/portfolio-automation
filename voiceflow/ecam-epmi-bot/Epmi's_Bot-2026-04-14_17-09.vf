  "functionPaths": [],
  "functionVariables": [
    {
      "id": "690776e4b702460cfd5aecce",
      "name": "variable1",
      "type": "input",
      "functionID": "690776deb702460cfd5aecca",
      "description": "",
      "createdAt": "2025-11-03T17:37:35.419Z"
