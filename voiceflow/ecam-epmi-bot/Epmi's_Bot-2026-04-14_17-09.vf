    },
    {
      "id": "690b96f510156b882d9bd74d",
      "name": "Closing",
      "createdByID": 1845656,
      "folderID": null,
      "settings": {
        "model": "gpt-4o",
        "maxTokens": 5000,
        "temperature": 0.3,
        "reasoningEffort": null
      },
      "description": "",
      "instructions": [
        {
          "text": [
            "You are the ECAM-EPMI closing agent.\nUse the ",
            {
              "variableID": "69076ccbb702460cfd5ae831"
            },
            " variable to reply.\nIf ",
            {
              "variableID": "69076ccbb702460cfd5ae831"
            },
            " = \"en\": say “Thanks, your request has been sent to the admissions team. You’ll receive a reply shortly.”\nIf ",
            {
              "variableID": "69076ccbb702460cfd5ae831"
            },
            " = \"fr\": say “Merci, votre demande a été transmise à l’équipe des admissions. Vous recevrez une réponse sous peu.”\n\nAfter outputting the message, terminate the conversation immediately.\nDo not continue, summarize, or reveal any internal details."
          ]
        }
      ],
