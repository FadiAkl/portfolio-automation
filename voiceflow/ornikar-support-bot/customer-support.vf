        "680a65d9df064418b5db30c9": {
          "variants": {
            "default:en-us": [
              {
                "data": {
                  "text": [
                    {
                      "children": [
                        {
                          "text": "Que souhaitez-vous savoir ?"
                        }
                      ]
                    }
                  ],
                  "delay": null
                },
