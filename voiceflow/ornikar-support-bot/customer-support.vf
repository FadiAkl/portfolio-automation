      "intentID": "6800d9de00fd6f4782305f57",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec80998",
      "text": [
        "Puis-je prendre rendez-vous dans l’un de vos showrooms ?"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec80999",
      "text": [
        "Puis-je prendre rendez-vous pour quelqu’un d’autre ?"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec8099a",
      "text": [
        "Puis-je prendre rendez-vous en ligne seulement en médecine de famille ?"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec8099b",
      "text": [
        "Je vous donne rendez-vous devant le restaurant"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec8099c",
      "text": [
        "Je vous propose qu’on se retrouve ce soir à six heures et quart, devant le restaurant Le Bastille"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec8099d",
      "text": [
        "Voulez-vous prendre un rendez-vous ?"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec8099e",
      "text": [
        "Comment puis-je prendre rendez-vous avec un médecin de famille ?"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec8099f",
      "text": [
        "Comment puis-je prendre rendez-vous avec un évaluateur ?"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809a0",
      "text": [
        "Comment puis-je prendre rendez-vous ?"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809a1",
      "text": [
        "Je souhaiterais convenir d’un rendez-vous avec vous pour discuter de [thème ou opportunité]"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809a2",
      "text": [
        "Je voudrais prendre un rendez-vous avec qqn"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809a3",
      "text": [
        "Je voudrais prendre rendez-vous avec qqn"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809a4",
      "text": [
        "Je voudrais prendre un rendez-vous avec un représentant"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809a5",
      "text": [
        "Je voudrais prendre rendez-vous pour vous voir cet après-midi"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809a6",
      "text": [
        "Je voudrais prendre rendez-vous dans votre salon pour aujourd'hui"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809a7",
      "text": [
        "Je voudrais prendre rendez-vous pour mon mari"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809a8",
      "text": [
        "Je voudrais prendre rendez-vous afin de visiter ce bien"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809a9",
      "text": [
        "Quand seriez-vous disponible pour une rencontre ?"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809aa",
      "text": [
        "Avez-vous des plages horaires disponibles pour un rendez-vous ?"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809ab",
      "text": [
        "Pouvez-vous me dire quand vous seriez libre pour se rencontrer ?"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809ac",
      "text": [
        "Quelle est votre disponibilité la semaine prochaine ?"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809ad",
      "text": [
        "Voulez-vous prendre un rendez-vous pour une évaluation en français ou en anglais ?"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809ae",
      "text": [
        "Je voudrais un rendez-vous pour une consultation"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809af",
      "text": [
        "J'aimerais avoir un rendez-vous (pour une consultation)"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809b0",
      "text": [
        "Je souhaiterais un rendez-vous avec M. Blanc, s'il vous plaît"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809b1",
      "text": [
        "J’aimerais prendre un rendez-vous avec le docteur Martin"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809b2",
      "text": [
        "Je souhaiterais prendre rendez-vous avec M. / Mme [nom]"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809b3",
      "text": [
        "J’aimerais prendre un rendez-vous avec le docteur Pichon s’il vous plaît"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809b4",
      "text": [
        "Je voudrais prendre rendez-vous avec monsieur Marc Duchamp"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6802b9f6de7198d1aec809b5",
      "text": [
        "Je voudrais prendre rendez-vous"
      ],
      "intentID": "6802b9f6de7198d1aec80997",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4802",
      "text": [
        "Non merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4803",
      "text": [
        "C’est bon, merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4804",
      "text": [
        "Je vous remercie, mais non."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4805",
      "text": [
        "Non, ça ira."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4806",
      "text": [
        "Je n’ai pas d’autres questions, merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4807",
      "text": [
        "Merci, je n’ai pas besoin de plus."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4808",
      "text": [
        "Non, tout est clair, merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4809",
      "text": [
        "Non, ça ira pour moi."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e480a",
      "text": [
        "Merci, je n’ai rien à ajouter."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e480b",
      "text": [
        "Non, je pense que c’est tout."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e480c",
      "text": [
        "Non, je vous remercie pour votre aide."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e480d",
      "text": [
        "Merci, je n’ai pas d’autres interrogations."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e480e",
      "text": [
        "Cela suffira, merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e480f",
      "text": [
        "Merci, je n’ai pas besoin de précisions supplémentaires."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4810",
      "text": [
        "Non, cela répond à toutes mes questions."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4811",
      "text": [
        "Je vous remercie, mais je n’ai pas besoin de plus."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4812",
      "text": [
        "Merci, c’est très clair."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4813",
      "text": [
        "Merci pour votre disponibilité, je n’ai pas de questions."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4814",
      "text": [
        "Non, tout est en ordre."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4815",
      "text": [
        "Non, je suis satisfait(e), merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4816",
      "text": [
        "Non, c’est bon."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4817",
      "text": [
        "Je suis ok, merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4818",
      "text": [
        "Non, pas besoin."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4819",
      "text": [
        "Nan, t’inquiète."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e481a",
      "text": [
        "Non, j’ai tout ce qu’il me faut."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e481b",
      "text": [
        "Non merci, ça ira."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e481c",
      "text": [
        "Je pense que ça va aller."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e481d",
      "text": [
        "C’est clair, pas de souci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e481e",
      "text": [
        "Non, nickel pour moi."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e481f",
      "text": [
        "Tranquille, merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4820",
      "text": [
        "Merci pour tout, je n’ai plus de questions."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4821",
      "text": [
        "Je pense qu’on a fait le tour."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4822",
      "text": [
        "Non, je n’ai rien d’autre à dire."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4823",
      "text": [
        "Non, pas pour le moment."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4824",
      "text": [
        "Non merci, ça ira très bien."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4825",
      "text": [
        "Non, pas d’inquiétude."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4826",
      "text": [
        "Merci, c’est compris."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4827",
      "text": [
        "Tout est bon pour moi."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4828",
      "text": [
        "Je n’ai plus besoin d’aide, merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4829",
      "text": [
        "C’est réglé, merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e482a",
      "text": [
        "Non, tout est sous contrôle."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e482b",
      "text": [
        "Non, je gère."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e482c",
      "text": [
        "Je n’ai rien à ajouter, merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e482d",
      "text": [
        "Merci, c’est tout ce qu’il me fallait."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e482e",
      "text": [
        "Non, j’ai ma réponse."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e482f",
      "text": [
        "Non, pas cette fois."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4830",
      "text": [
        "Merci beaucoup, je n’ai pas de questions."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4831",
      "text": [
        "Non, pas aujourd’hui."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4832",
      "text": [
        "Merci, mais c’est bon."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4833",
      "text": [
        "Non, j’ai compris."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4834",
      "text": [
        "Non, rien d’autre à signaler."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4835",
      "text": [
        "Non, c’est terminé pour moi."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4836",
      "text": [
        "Merci, mais je passe mon tour."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4837",
      "text": [
        "Non, rien de plus à dire."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4838",
      "text": [
        "Merci, c’est tout pour moi."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4839",
      "text": [
        "Non, je pense qu’on a tout couvert."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e483a",
      "text": [
        "Je n’ai rien à demander."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e483b",
      "text": [
        "Non, je n’ai besoin de rien d’autre."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e483c",
      "text": [
        "Non, on peut s’arrêter là."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e483d",
      "text": [
        "Non, je crois qu’on a fini."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e483e",
      "text": [
        "Merci, j’ai tout ce qu’il me faut."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e483f",
      "text": [
        "Non, ça suffit pour aujourd’hui."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4840",
      "text": [
        "Je suis bon(ne), merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4841",
      "text": [
        "Non, je n’ai pas de remarque."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4842",
      "text": [
        "Merci, j’en reste là."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4843",
      "text": [
        "Non, je suis tranquille."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4844",
      "text": [
        "Non merci, c’est déjà bien."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4845",
      "text": [
        "Merci, c’est assez."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4846",
      "text": [
        "Non, je suis ok avec ça."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4847",
      "text": [
        "Non, pas de soucis."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4848",
      "text": [
        "Merci, je passe."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4849",
      "text": [
        "Non, aucune question supplémentaire."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e484a",
      "text": [
        "Non, je suis content(e) comme ça."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e484b",
      "text": [
        "Merci, je ne vais pas plus loin."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e484c",
      "text": [
        "Non, tout est couvert."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e484d",
      "text": [
        "Non, je n’ai pas de retour pour l’instant."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e484e",
      "text": [
        "Merci, je pense que c’est bon."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e484f",
      "text": [
        "Non, je n’ai rien à redire."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4850",
      "text": [
        "Merci, j’ai tout pigé."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4851",
      "text": [
        "Non, c’est réglé de mon côté."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4852",
      "text": [
        "Je n’ai pas de question, merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4853",
      "text": [
        "Non, c’est tout bon."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4854",
      "text": [
        "Merci, c’est terminé."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4855",
      "text": [
        "Non, plus rien à ajouter."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4856",
      "text": [
        "Merci, c’est parfait comme ça."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4857",
      "text": [
        "Non, rien à signaler."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4858",
      "text": [
        "Merci, je ne reviendrai pas dessus."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4859",
      "text": [
        "Non, je pense qu’on a tout dit."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e485a",
      "text": [
        "Merci, c’est bouclé."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e485b",
      "text": [
        "Non, on peut conclure."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e485c",
      "text": [
        "Je suis satisfait, merci."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e485d",
      "text": [
        "Non, rien à mentionner."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e485e",
      "text": [
        "Merci, je suis bon(ne)."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e485f",
      "text": [
        "Non, rien d’autre."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4860",
      "text": [
        "Merci, je suis rassuré(e)."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4861",
      "text": [
        "Non, c’est fini pour moi."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4862",
      "text": [
        "Merci, j’ai ce qu’il me faut."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4863",
      "text": [
        "Non, je n’ai pas d’observation."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4864",
      "text": [
        "Non, c’est suffisant."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4865",
      "text": [
        "Merci, je n’ai plus de doute."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4866",
      "text": [
        "Non, j’ai tout compris."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4867",
      "text": [
        "Non, je n’ai rien oublié."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4868",
      "text": [
        "Non, on a fait le tour."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "680a2559b98100cb0a9e4869",
      "text": [
        "Merci, c’est top."
      ],
      "intentID": "6797c2110cfd6c00ccbedd9f",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    }
  ],
