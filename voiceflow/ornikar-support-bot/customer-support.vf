    {
      "id": "6800df4e00fd6f4782306294",
      "text": [
        {
          "text": [
            "J'aimerais parler à un être humain."
          ]
        }
      ],
      "intentID": "6800d9de00fd6f4782305f57",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6800d9de00fd6f4782305f58",
      "text": [
        {
          "text": [
            "Je veux parler à un conseiller humain."
          ]
        }
      ],
      "intentID": "6800d9de00fd6f4782305f57",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6800d9de00fd6f4782305f59",
      "text": [
        {
          "text": [
            "Puis‑je être mis en relation avec un agent ?"
          ]
        }
      ],
      "intentID": "6800d9de00fd6f4782305f57",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6800d9de00fd6f4782305f5a",
      "text": [
        {
          "text": [
            "Transférez-moi vers un opérateur humain, s’il vous plaît."
          ]
        }
      ],
      "intentID": "6800d9de00fd6f4782305f57",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6800d9de00fd6f4782305f5b",
      "text": [
        {
          "text": [
            "Je souhaite parler à un être humain."
          ]
        }
      ],
      "intentID": "6800d9de00fd6f4782305f57",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6800d9de00fd6f4782305f5c",
      "text": [
        {
          "text": [
            "Un conseiller réel, pas un robot, s’il vous plaît."
          ]
        }
      ],
      "intentID": "6800d9de00fd6f4782305f57",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6800d9de00fd6f4782305f5d",
      "text": [
        {
          "text": [
            "Je voudrais échanger avec un membre de votre équipe."
          ]
        }
      ],
      "intentID": "6800d9de00fd6f4782305f57",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6800d9de00fd6f4782305f5e",
      "text": [
        {
          "text": [
            "Faites appel à un agent humain pour cette question."
          ]
        }
      ],
      "intentID": "6800d9de00fd6f4782305f57",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6800d9de00fd6f4782305f5f",
      "text": [
        {
          "text": [
            "Je refuse de parler à un robot, mettez‑moi en contact avec un humain."
          ]
        }
      ],
      "intentID": "6800d9de00fd6f4782305f57",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6800d9de00fd6f4782305f60",
      "text": [
        {
          "text": [
            "Pouvez‑vous me passer à un humain ?"
          ]
        }
      ],
      "intentID": "6800d9de00fd6f4782305f57",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
      "id": "6800d9de00fd6f4782305f61",
      "text": [
        {
          "text": [
            "Je préfère discuter avec un conseiller en chair et en os."
          ]
        }
      ],
      "intentID": "6800d9de00fd6f4782305f57",
      "language": "en-us",
      "createdAt": "2025-05-07T16:34:29.000Z"
    },
    {
